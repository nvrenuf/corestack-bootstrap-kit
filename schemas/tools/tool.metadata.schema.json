{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corestack.dev/schemas/tools/tool.metadata.schema.json",
  "title": "Corestack Tool Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tool",
    "backend"
  ],
  "properties": {
    "tool": {
      "type": "string",
      "enum": [
        "web.fetch",
        "web.search"
      ]
    },
    "backend": {
      "type": "string",
      "minLength": 1
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decision_id",
        "outcome"
      ],
      "properties": {
        "decision_id": {
          "type": "string",
          "minLength": 1
        },
        "outcome": {
          "type": "string",
          "enum": [
            "allow",
            "deny",
            "require_approval"
          ]
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": true
    },
    "required_permissions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
