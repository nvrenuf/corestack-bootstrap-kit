{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://corestack.dev/schemas/policy/decision.schema.json",
  "title": "Corestack Policy Decision Contract",
  "type": "object",
  "additionalProperties": false,
  "required": ["request", "decision"],
  "properties": {
    "request": { "$ref": "#/$defs/governed_action_request" },
    "decision": { "$ref": "#/$defs/policy_decision" }
  },
  "$defs": {
    "actor_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["actor_id", "actor_type"],
      "properties": {
        "actor_id": { "type": "string", "minLength": 1 },
        "actor_type": { "type": "string", "minLength": 1 }
      }
    },
    "object_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "id": { "type": ["string", "null"] },
        "capability": { "type": ["string", "null"] },
        "locator": { "type": ["string", "null"] },
        "scope": {
          "type": ["array", "null"],
          "items": { "type": "string", "minLength": 1 }
        },
        "classification": { "type": ["string", "null"] }
      }
    },
    "reason": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "audit_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event_type", "correlation_id"],
      "properties": {
        "event_type": { "type": "string", "minLength": 1 },
        "correlation_id": { "type": "string", "minLength": 1 },
        "requested_at": { "type": ["string", "null"] },
        "decided_at": { "type": ["string", "null"] },
        "decision_trace_id": { "type": ["string", "null"] }
      }
    },
    "approval_ref": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required", "subject_ref"],
      "properties": {
        "required": { "const": true },
        "subject_ref": { "type": "string", "minLength": 1 },
        "queue": { "type": ["string", "null"] },
        "approver_role": { "type": ["string", "null"] },
        "expires_at": { "type": ["string", "null"] }
      }
    },
    "obligation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "params": { "type": "object", "additionalProperties": true }
      }
    },
    "governed_action_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "action", "purpose", "subject", "resource", "context", "audit"],
      "properties": {
        "request_id": { "type": "string", "minLength": 1 },
        "action": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "subject": { "$ref": "#/$defs/object_ref" },
        "resource": { "$ref": "#/$defs/object_ref" },
        "context": {
          "type": "object",
          "additionalProperties": false,
          "required": ["actor", "correlation_id"],
          "properties": {
            "actor": { "$ref": "#/$defs/actor_ref" },
            "module_id": { "type": ["string", "null"] },
            "workflow_id": { "type": ["string", "null"] },
            "run_id": { "type": ["string", "null"] },
            "case_id": { "type": ["string", "null"] },
            "deployment": { "type": "object", "additionalProperties": true },
            "correlation_id": { "type": "string", "minLength": 1 }
          }
        },
        "audit": { "$ref": "#/$defs/audit_ref" }
      }
    },
    "policy_decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["decision_id", "request_id", "outcome", "reasons", "decided_at", "audit"],
      "properties": {
        "decision_id": { "type": "string", "minLength": 1 },
        "request_id": { "type": "string", "minLength": 1 },
        "outcome": {
          "type": "string",
          "enum": ["allow", "deny", "require_approval"]
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/reason" }
        },
        "obligations": {
          "type": "array",
          "items": { "$ref": "#/$defs/obligation" }
        },
        "approval": {
          "anyOf": [
            { "$ref": "#/$defs/approval_ref" },
            { "type": "null" }
          ]
        },
        "policy_ref": {
          "type": ["object", "null"],
          "additionalProperties": true
        },
        "expires_at": { "type": ["string", "null"] },
        "decided_at": { "type": "string", "minLength": 1 },
        "audit": { "$ref": "#/$defs/audit_ref" }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "outcome": { "const": "require_approval" }
            }
          },
          "then": {
            "required": ["approval"]
          }
        }
      ]
    }
  }
}
