{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://corestack.local/packs/fear-signal-radar/schemas/topic_config.schema.json",
  "title": "Fear Signal Radar TopicConfig",
  "description": "Strict topic configuration contract for FSRA collectors and scoring.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "topic_id",
    "pillar",
    "description",
    "keywords_primary",
    "platforms_enabled",
    "scoring_weights"
  ],
  "properties": {
    "topic_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique topic identifier"
    },
    "pillar": {
      "type": "string",
      "minLength": 1,
      "description": "The strategy pillar this topic belongs to"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "description": "Human-readable topic description"
    },
    "keywords_primary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Primary search keywords"
    },
    "keywords_secondary": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Secondary search keywords"
    },
    "platforms_enabled": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "reddit",
          "youtube",
          "news"
        ]
      },
      "description": "Enabled collector platforms"
    },
    "subreddits": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Required when reddit is enabled"
    },
    "youtube_queries": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Required when youtube is enabled"
    },
    "news_queries": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Search queries for news collection"
    },
    "rss_feeds": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "RSS feed URLs"
    },
    "time_window_days": {
      "type": "integer",
      "minimum": 1,
      "default": 7,
      "description": "Lookback window for collection"
    },
    "language": {
      "type": "string",
      "default": "en",
      "minLength": 1,
      "description": "Language code"
    },
    "exclusions": {
      "type": "array",
      "default": [],
      "items": {
        "type": "string",
        "minLength": 1
      },
      "description": "Keywords to suppress from scoring"
    },
    "scoring_weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "volume",
        "velocity",
        "cross_platform",
        "impact"
      ],
      "properties": {
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "velocity": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "cross_platform": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        },
        "impact": {
          "type": "number",
          "minimum": 0,
          "maximum": 5
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "platforms_enabled": {
            "contains": {
              "const": "reddit"
            }
          }
        },
        "required": [
          "platforms_enabled"
        ]
      },
      "then": {
        "required": [
          "subreddits"
        ],
        "properties": {
          "subreddits": {
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "platforms_enabled": {
            "contains": {
              "const": "youtube"
            }
          }
        },
        "required": [
          "platforms_enabled"
        ]
      },
      "then": {
        "required": [
          "youtube_queries"
        ],
        "properties": {
          "youtube_queries": {
            "minItems": 1
          }
        }
      }
    }
  ]
}
